{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "runner",
      "type": "shell",
      "command": "npm start",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "owner": "react",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting the development server",
          "endsPattern": "Compiled successfully"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Dev Server"
      }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Build"
      },
      "problemMatcher": []
    },
    {
      "label": "deploy",
      "type": "shell",
      "command": "git push origin main",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Deploy"
      },
      "problemMatcher": []
    }
  ]
}
